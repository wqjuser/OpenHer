# OpenHer Environment Variables
# Copy this file to .env and fill in your API keys

# LLM Provider
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DEFAULT_MODEL=qwen3-max
DEFAULT_PROVIDER=dashscope

# Optional: OpenAI (for GPT-4o)
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: generic LLM override convention
# Any provider can use <PROVIDER>_API_KEY / <PROVIDER>_BASE_URL, e.g.
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# Or use LLM_API_KEY / LLM_BASE_URL as a fallback for the selected provider.
# LLM_API_KEY=your_current_llm_api_key_here
# LLM_BASE_URL=https://your-llm-gateway.example/v1

# Optional: DeepSeek (OpenAI-compatible)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEFAULT_PROVIDER=deepseek
# DEFAULT_MODEL=deepseek-v4-pro

# Optional: media provider keys
# Provider-specific variables still win. These generic fallbacks apply to the
# selected TTS/image provider when its provider-specific key is not set.
# TTS_API_KEY=your_current_tts_api_key_here
# IMAGE_API_KEY=your_current_image_api_key_here

# Optional: provider-specific media keys
# DASHSCOPE_API_KEY=your_dashscope_tts_api_key_here
# GEMINI_API_KEY=your_gemini_image_api_key_here

# Server security
# Set OPENHER_API_TOKEN to require Bearer auth for HTTP APIs and WebSocket.
# OPENHER_API_TOKEN=change_me_to_a_long_random_token
# OPENHER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8800

# EverMemOS Long-Term Memory (optional)
# Cloud: set only the key; OpenHer uses the default cloud URL.
# EVERMEMOS_API_KEY=your_evermemos_api_key_here
# Self-hosted/private gateway: override the URL explicitly.
# EVERMEMOS_BASE_URL=http://localhost:1995/api/v1
# Optional generic memory fallback convention.
# EVERMEMOS_* variables still win when both are set.
# MEMORY_API_KEY=your_current_memory_api_key_here
# MEMORY_BASE_URL=http://localhost:1995/api/v1
